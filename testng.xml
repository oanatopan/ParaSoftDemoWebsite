<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="ParaBank UI Automation Suite">

    <listeners>
        <listener class-name="utils.TestListener"/>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <test name="Regression Tests">
        <classes>
            <class name="tests.RegisterTest"/>
            <class name="tests.LoginValidTest"/>
            <class name="tests.OpenAccountTest"/>
            <class name="tests.TransferFundsTest"/>
            <class name="tests.BillPayTest"/>
            <class name="tests.RequestLoanTest"/>
            <class name="tests.FindTransactionsTest"/>
            <class name="tests.AccountHistoryTest"/>
            <class name="tests.AccountsOverviewTest"/>
            <class name="tests.LogOutTest"/>
            <class name="tests.LoginInvalidTest"/>
        </classes>
    </test>

</suite>